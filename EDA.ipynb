   "source": [
    "### Class Distribution\n",
    "\n",
    "The dataset is nearly perfectly balanced \u2014 ~51% quark, ~49% gluon. No resampling is needed, and standard metrics like accuracy are reliable as-is.\n"
   ],
   "metadata": {}
  },
  {
   "cell_type": "code",
   "source": "import matplotlib.pyplot as plt\nunique, counts = np.unique(label, return_counts=True)\nprint(f'Unique label: {unique}')\nprint(f'Counts:        {counts}')\nprint(f'Class 0 (quark): {counts[0]} ({counts[0]/len(label)*100:.1f}%)')\nprint(f'Class 1 (gluon): {counts[1]} ({counts[1]/len(label)*100:.1f}%)')\nprint(f'Balance ratio:   {label.mean():.4f}')\n\nfig, ax = plt.subplots(figsize=(6, 4))\nax.bar(['Class 0\\n(Quark)', 'Class 1\\n(Gluon)'], counts, color=['#2196F3', '#FF5722'], edgecolor='black')\nax.set_ylabel('Count')\nax.set_title('Label Distribution (10,000 labelled samples)')\nfor i, (c, v) in enumerate(zip(counts, counts)):\n    ax.text(i, v + 50, f'{v}\\n({v/len(label)*100:.1f}%)', ha='center', fontsize=11)\nax.set_ylim(0, max(counts) * 1.15)\nplt.tight_layout()\nplt.savefig('eda_label_distribution.jpg', dpi=150)\nplt.show()",
