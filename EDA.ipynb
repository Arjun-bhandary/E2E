   "source": "# Compute radial distance from center (62, 62)\ncy, cx = 62, 62\ny, x = np.ogrid[:125, :125]\nr = np.sqrt((y - cy)**2 + (x - cx)**2)\n\n# Radial profile for ECAL (Ch4) \u2014 most active channel\nmax_r = 60\nbins = np.arange(0, max_r + 1, 1)\n\ndef radial_profile(images, channel, r_map, bins):\n    profile = np.zeros(len(bins) - 1)\n    counts = np.zeros(len(bins) - 1)\n    for img in images:\n        ch_img = img[:, :, channel]\n        for i in range(len(bins) - 1):\n            mask = (r_map >= bins[i]) & (r_map < bins[i+1])\n            profile[i] += ch_img[mask].sum()\n            counts[i] += mask.sum() * len(images)\n    return profile / np.maximum(counts, 1)\n\n# Use a subset for speed\nn_prof = min(200, len(quark_samples))\nquark_prof = radial_profile(quark_samples[:n_prof], 4, r, bins)\ngluon_prof = radial_profile(gluon_samples[:n_prof], 4, r, bins)\n\nfig, ax = plt.subplots(figsize=(10, 6))\nbin_centers = (bins[:-1] + bins[1:]) / 2\nax.plot(bin_centers, quark_prof, 'b-', lw=2, label='Quark')\nax.plot(bin_centers, gluon_prof, 'r-', lw=2, label='Gluon')\nax.set_xlabel('Distance from Jet Center (pixels)')\nax.set_ylabel('Mean ECAL Energy per Pixel')\nax.set_title('Radial Energy Profile \u2014 ECAL (Ch4)')\nax.legend(fontsize=12)\nax.grid(True, alpha=0.3)\nax.set_xlim(0, max_r)\nplt.tight_layout()\nplt.savefig('eda_radial_profile.jpg', dpi=150)\nplt.show()",
