   "cell_type": "code",
   "source": "def load_jet_h5(path, load_label=False):\n  with h5py.File(path, 'r') as f:\n    jet = f['jet']\n    N = jet.shape[0]\n\n    # preallocate full array\n    data = np.empty(jet.shape, dtype=jet.dtype)\n\n    # label (only if present)\n    label = None\n    if load_label and 'Y' in f:\n      label = f['Y'][:].squeeze()\n\n    # load with progress bar\n    for i in tqdm(range(N), desc=f\"Loading {path.split('/')[-1]}\"):\n      data[i] = jet[i]\n\n  return data, label",
